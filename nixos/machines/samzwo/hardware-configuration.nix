  fileSystems."/" =
    { device = "/dev/mapper/nixos-root";
      fsType = "ext4";
    };

  fileSystems."/home" =
    { device = "/dev/mapper/nixos-home";
      fsType = "ext4";
    };

  fileSystems."/var" =
    { device = "/dev/mapper/nixos-var";
      fsType = "ext4";
    };

  fileSystems."/var/log" =
    { device = "/dev/mapper/nixos-varlog";
      fsType = "ext4";
    };

  fileSystems."/boot" =
    { device = "/dev/disk/by-uuid/4251-D6B1";
      fsType = "vfat";
      options = [ "fmask=0022" "dmask=0022" ];
    };

  swapDevices =
    [ { device = "/dev/disk/by-uuid/7db50049-ce58-41e7-bb51-5ebfb35edb3f"; }
    ];

  nixpkgs.hostPlatform = lib.mkDefault "x86_64-linux";
  hardware.cpu.amd.updateMicrocode = lib.mkDefault config.hardware.enableRedistributableFirmware;
}
